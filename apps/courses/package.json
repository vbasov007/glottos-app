{
  "name": "@glottos/courses",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build:content": "tsx scripts/build-content.ts",
    "codes": "tsx scripts/build-share-codes.ts",
    "codes:sections": "tsx scripts/build-audio-section-codes.ts",
    "vocab": "tsx scripts/build-vocab-codes.ts",
    "practice": "tsx scripts/build-practice-codes.ts",
    "audit:dict": "tsx scripts/audit-dictionary.ts",
    "cleanup:dict": "tsx scripts/cleanup-dictionary.ts",
    "cefr": "tsx scripts/build-cefr-levels.ts",
    "course:gen": "tsx scripts/build-course-content.ts",
    "dict:rebuild": "tsx scripts/build-dictionary.ts",
    "cefr:normalize": "tsx scripts/normalize-cefr-levels.ts",
    "db:init": "tsx scripts/db-init.ts",
    "audit:mobile": "tsx scripts/audit-mobile.ts",
    "audit:mobile:install": "playwright install chromium",
    "test:sso": "node --env-file-if-exists=.env.local node_modules/.bin/tsx scripts/test-sso-link.ts",
    "prebuild": "npm run build:content",
    "dev": "node --env-file-if-exists=.env.local node_modules/.bin/next dev",
    "build": "next build",
    "start": "node --env-file-if-exists=.env.local node_modules/.bin/next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@glottos/shared": "*",
    "@anthropic-ai/sdk": "^0.39.0",
    "@react-oauth/google": "^0.13.4",
    "google-auth-library": "^10.6.1",
    "minisearch": "^7.1.2",
    "next": "^15.5.0",
    "next-intl": "^4.4.0",
    "pg": "^8.19.0",
    "posthog-js": "^1.374.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^9.0.3",
    "rehype-raw": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/unist": "^3.0.3",
    "autoprefixer": "^10.4.20",
    "mdast-util-to-string": "^4.0.0",
    "postcss": "^8.5.0",
    "remark-parse": "^11.0.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0",
    "vitest": "^2.1.8"
  }
