# Build context is the parent dir, so the sub-repos' own .dockerignore files do
# not apply. BuildKit uses THIS file (named <dockerfile>.dockerignore) instead.
# Patterns are relative to the build context root.

**/node_modules
**/.git
**/.env
**/.env.*
**/.next
**/dist
**/build-info.json
glottos-courses/web/content/.generated
**/test-results
**/playwright-report
**/.claude
**/*.log
