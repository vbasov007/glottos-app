# Rendered by entrypoint.sh (envsubst) -> /etc/nginx/nginx.conf
# Edge router for the combined container. TLS is terminated upstream
# (Cloudflare / load balancer); we serve plain HTTP on :80 and route by Host.

worker_processes auto;
error_log /dev/stderr warn;
pid /run/nginx.pid;

events { worker_connections 1024; }

http {
    include       /etc/nginx/mime.types;
    default_type  application/octet-stream;

    log_format main '$remote_addr - $host "$request" $status $body_bytes_sent';
    access_log /dev/stdout main;

    sendfile on;
    keepalive_timeout 65;

    # Only send "Connection: upgrade" for actual WebSocket handshakes; keep
    # plain HTTP keepalive otherwise.
    map $http_upgrade $connection_upgrade {
        default upgrade;
        ''      close;
    }

    # LLM / TTS responses can be slow and are sometimes streamed.
    proxy_http_version 1.1;
    proxy_read_timeout 300s;
    proxy_send_timeout 300s;
    send_timeout 300s;
    client_max_body_size 25m;

    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $http_x_forwarded_proto;
    proxy_set_header X-Forwarded-Host $host;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection $connection_upgrade;

    upstream courses_upstream { server 127.0.0.1:8080; }
    upstream tutor_upstream   { server 127.0.0.1:4000; }

    # glottos-courses (Next.js)
    server {
        listen 80;
        server_name ${COURSES_HOST};
        location / {
            proxy_pass http://courses_upstream;
            proxy_buffering off;
        }
    }

    # text-tutor (Express + SPA)
    server {
        listen 80;
        server_name ${TUTOR_HOST};
        location / {
            proxy_pass http://tutor_upstream;
            proxy_buffering off;
        }
    }

    # Unknown Host -> courses (also answers health checks hitting the raw IP).
    server {
        listen 80 default_server;
        server_name _;
        location / {
            proxy_pass http://courses_upstream;
            proxy_buffering off;
        }
    }
}
