# =========================================================================
# Combined glottos-courses + text-tutor deployment — copy to .env and fill in.
# =========================================================================

# ----- Routing (nginx Host-based) -----------------------------------------
# The two public subdomains. TLS is terminated upstream; point both DNS names
# at this server. Used by nginx (runtime) AND the compose healthcheck.
COURSES_HOST=courses.glottos.com
TUTOR_HOST=t.glottos.com

# ----- Databases (external / managed Postgres) ----------------------------
# Two SEPARATE databases — the apps' users/sessions schemas conflict.
DATABASE_URL_COURSES=postgresql://user:pass@db-host:5432/courses?sslmode=require
DATABASE_URL_TUTOR=postgresql://user:pass@db-host:5432/textutor?sslmode=require

# ===== ONE LOGIN — these MUST match across both apps ======================
# Same Google OAuth client ID everywhere => same google_sub => same identity.
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
# Same shared secret in both apps (32+ random bytes). Server-only, never public.
SSO_SHARED_SECRET=replace-with-32+-random-bytes
# Cross-app base URLs (build-time; inlined into the bundles). Use the subdomains.
NEXT_PUBLIC_TUTOR_URL=https://t.glottos.com
COURSES_URL=https://courses.glottos.com
# ==========================================================================

# ----- glottos-courses (runtime) ------------------------------------------
ANTHROPIC_API_KEY=
GOOGLE_TTS_API_KEY=
ADMIN_USER=
SESSION_TTL_DAYS=30
# Optional Azure TTS fallback
AZURE_TTS_KEY=
AZURE_TTS_REGION=

# ----- glottos-courses (build-time) ---------------------------------------
SITE_URL=https://courses.glottos.com
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
NEXT_PUBLIC_TMA_DEFAULT_TARGET=de

# ----- text-tutor (runtime) -----------------------------------------------
GEMINI_API_KEY=
ADMIN_EMAIL=
APP_URL=https://t.glottos.com
ALLOWED_ORIGINS=https://t.glottos.com,https://courses.glottos.com
# Optional integrations
OPENAI_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ----- Shared optional -----------------------------------------------------
TELEGRAM_BOT_TOKEN=
