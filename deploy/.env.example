# =====================================================================
# Merged glottos app — ALL environment variables for BOTH apps.
# Copy to `.env` at the repo root and fill in. Never commit real secrets.
#
# One process environment feeds both the courses (Next.js) and tutor (Express)
# processes. Shared vars are listed ONCE at the top; the "old -> new" column
# maps each legacy variable to its place here.
# =====================================================================

# ---------------------------------------------------------------------
# SHARED — one value used by both apps (this is what makes the merge "one
# user system"). old(courses) / old(tutor) -> new
# ---------------------------------------------------------------------

# ONE unified Postgres database.  (was: DATABASE_URL_COURSES + DATABASE_URL_TUTOR)
DATABASE_URL=postgresql://glottos:glottos@localhost:5433/glottos

# ONE Google OAuth client for both apps -> identical google_sub across the app.
# (courses: GOOGLE_CLIENT_ID / tutor: GOOGLE_CLIENT_ID) -> GOOGLE_CLIENT_ID
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
# Client-side copies (inlined at build). Same value as above.
# courses reads NEXT_PUBLIC_GOOGLE_CLIENT_ID; tutor reads GOOGLE_CLIENT_ID (Vite define).
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Admin email that gets role='admin' on login. Both legacy names are accepted by
# the shared helper; set either. (courses: ADMIN_USER / tutor: ADMIN_EMAIL)
ADMIN_USER=you@example.com
# ADMIN_EMAIL=you@example.com

# Session lifetime in days (both apps).  (courses: SESSION_TTL_DAYS / tutor: constant 30)
SESSION_TTL_DAYS=30

# Cross-app SSO handoff secret. Still supported (external deep-links / /s share
# flow) but NO LONGER required for login now that both apps share one origin +
# one sessions table. Must be identical if used. (both: SSO_SHARED_SECRET)
SSO_SHARED_SECRET=replace-with-32-plus-random-bytes

# Telegram Mini App bot token (both apps).  (both: TELEGRAM_BOT_TOKEN)
TELEGRAM_BOT_TOKEN=

# Azure TTS (both apps).  (both: AZURE_TTS_KEY / AZURE_TTS_REGION)
AZURE_TTS_KEY=
AZURE_TTS_REGION=westeurope

# ---------------------------------------------------------------------
# ROUTING — single origin, path-based
# ---------------------------------------------------------------------
# courses is served under this base path (nginx /courses -> Next basePath).
# Set to '' to serve courses at the root instead (then move tutor elsewhere).
NEXT_PUBLIC_BASE_PATH=/courses
# Public origin (sitemap/canonical/OAuth redirect base) for courses.
SITE_URL=https://glottos.example.com/courses
# Cross-app link bases (used by the retained SSO "open in other app" helpers).
NEXT_PUBLIC_TUTOR_URL=https://glottos.example.com
COURSES_URL=https://glottos.example.com/courses
APP_URL=https://glottos.example.com
ALLOWED_ORIGINS=https://glottos.example.com

# ---------------------------------------------------------------------
# COURSES-ONLY (Next.js)
# ---------------------------------------------------------------------
ANTHROPIC_API_KEY=            # Claude answer-judging + exercise generation
GOOGLE_TTS_API_KEY=           # Google Cloud TTS (REST key)
NEXT_PUBLIC_POSTHOG_KEY=      # analytics (empty disables)
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
NEXT_PUBLIC_TMA_DEFAULT_TARGET=de
# POLYGLOTTOS_API_KEY=        # build-time only, share-code generation

# ---------------------------------------------------------------------
# TUTOR-ONLY (Express)
# ---------------------------------------------------------------------
GEMINI_API_KEY=               # primary LLM (explain / generate / OCR-adjacent)
# Optional providers / integrations
OPENAI_API_KEY=               # image OCR (vision)
DEEPSEEK_API_KEY=             # alternative LLM
YANDEX_TTS_API_KEY=           # optional TTS provider
GOOGLE_CLOUD_TTS_CREDENTIALS= # base64 GCP service-account JSON for @google-cloud/text-to-speech
GOOGLE_CLIENT_SECRET=         # server-side OAuth exchange for Telegram "link Google" flow
# Stripe (subscriptions). Unset = paywall disabled (unlimited dev mode).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Local Express port (nginx proxies / -> here). Prod pm2 sets PORT=4000.
SERVER_PORT=4000

# ---------------------------------------------------------------------
# DATA MIGRATION ONLY — the two LEGACY source databases (read-only).
# Used by `npm run migrate:legacy`. Leave unset for normal running.
# ---------------------------------------------------------------------
DATABASE_URL_COURSES_SRC=postgresql://user:pass@old-host:5432/courses?sslmode=require
DATABASE_URL_TUTOR_SRC=postgresql://user:pass@old-host:5432/textutor?sslmode=require
